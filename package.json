{
  "name": "hfup",
  "type": "module",
  "version": "1.0.2",
  "description": "A collection of tools to help you deploy, bundle HuggingFace Spaces and related assets with ease.",
  "keywords": [],
  "packageManager": "pnpm@10.30.3",
  "author": "Moeru AI",
  "license": "MIT",
  "homepage": "https://github.com/moeru-ai/hfup",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moeru-ai/hfup.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./cli": "./dist/cli.mjs",
    "./schema": "./dist/schema.mjs",
    "./json-schema.json": "./dist/json-schema.json",
    "./vite": "./dist/vite.mjs",
    "./webpack": "./dist/webpack.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./*": "./*"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "bin": {
    "hfup": "./dist/cli.mjs"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "rolldown -c && node scripts/write-schema.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "attw": "attw --pack . --profile esm-only --ignore-rules cjs-resolves-to-esm",
    "up": "taze -w -r -I -f && pnpm prune && pnpm dedupe"
  },
  "dependencies": {
    "defu": "^6.1.4",
    "gray-matter": "^4.0.3",
    "unplugin": "^2.3.11"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@importantimport/tsconfig": "^1.0.0-beta.2",
    "@types/node": "^24.11.0",
    "builtin-modules": "^5.0.0",
    "bumpp": "^10.4.1",
    "changelogithub": "^13.16.1",
    "oxlint": "^1.51.0",
    "rolldown": "^1.0.0-rc.7",
    "taze": "^19.10.0",
    "typescript": "^5.9.3",
    "unplugin-isolated-decl": "^0.15.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
